# ============================================================
# VEEAM CHATBOT CONFIG — EXAMPLE TEMPLATE
# Copy this file to config_final.env and fill in real values.
# Run: python encrypt_config.py   (to encrypt API keys)
# NEVER commit config_final.env — only commit this .example file.
# ============================================================

# ── Active Provider ─────────────────────────────────────────
# Options: groq | openrouter | lmstudio | gemini | openai | copilot | ollama
MODEL_PROVIDER=groq

# ── Providers shown in the chatbot UI dropdown ───────────────
# Only list providers you actually use — others stay hidden
ENABLED_PROVIDERS=groq,openrouter,lmstudio

# ── Groq (Free — Recommended for demo) ─────────────────────
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── OpenRouter (Free models available) ──────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# ── LM Studio (On-prem · Air-gapped · Zero external calls) ──
# 1. Open LM Studio → load a model → enable Local Server (port 1234)
# 2. Set MODEL_PROVIDER=lmstudio — zero data leaves your network
LMSTUDIO_URL=http://localhost:1234/v1/chat/completions
LMSTUDIO_MODEL=phi-3.5-mini-instruct

# ── Gemini (Free tier) ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI (Paid) ───────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# ── GitHub Copilot ──────────────────────────────────────────
COPILOT_API_KEY=your_copilot_token_here
COPILOT_MODEL=gpt-4o
COPILOT_URL=https://api.githubcopilot.com/chat/completions

# ── Ollama (Local — needs GPU or strong CPU) ────────────────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=phi3:mini

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=veeam_demo
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ── Flask ────────────────────────────────────────────────────
FLASK_PORT=5000

# ── Email / SMTP (Gmail example) ─────────────────────────────
# For Gmail: use an App Password, not your real password.
# Google Account → Security → 2FA → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient@company.com
